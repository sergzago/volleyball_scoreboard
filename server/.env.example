# ============================================================================
# Конфигурация базы данных
# ============================================================================
# Поддерживаемые провайдеры: firebase | pocketbase
DB_PROVIDER=firebase

# ----------------------------------------------------------------------------
# Firebase Admin SDK configuration
# Получите service account key из Firebase Console:
# Project Settings > Service Accounts > Generate New Private Key
# ----------------------------------------------------------------------------

# Вариант 1: Путь к JSON файлу сервисного аккаунта (рекомендуется)
# FIREBASE_KEY_FILE_PATH=/path/to/serviceAccountKey.json

# Вариант 2: Переменные окружения
FIREBASE_PROJECT_ID=myvolleyscore
FIREBASE_CLIENT_EMAIL=your-service-account@myvolleyscore.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----------------------------------------------------------------------------
# PocketBase configuration (если DB_PROVIDER=pocketbase)
# ----------------------------------------------------------------------------
POCKETBASE_URL=http://zago.my.to:8090
POCKETBASE_ADMIN_EMAIL=admin@volleyball.local
POCKETBASE_ADMIN_PASSWORD=your_admin_password

# ----------------------------------------------------------------------------
# Общие настройки
# ----------------------------------------------------------------------------
PORT=3000
ALLOWED_ORIGINS=*
